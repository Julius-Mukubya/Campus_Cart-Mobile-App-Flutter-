rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — allow any authenticated user to read
    // Allow write if: user owns the document OR the requester is an admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /paymentMethods/{methodId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /cart/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /wishlist/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sellerRequests/{requestId} {
      allow read, write: if request.auth != null;
    }

    match /seller_approval_requests/{requestId} {
      allow read, write: if request.auth != null;
    }

    match /store_approval_requests/{requestId} {
      allow read, write: if request.auth != null;
    }

    match /batches/{batchId} {
      allow read, write: if request.auth != null;
    }

    match /payouts/{payoutId} {
      allow read, write: if request.auth != null;
    }
  }
}
